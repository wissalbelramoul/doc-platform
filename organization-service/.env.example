DEBUG=True
SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=*

DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Legacy compatibility for older local setups
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_EXCHANGE=organisation_events
RABBITMQ_QUEUE=organisation_service.inbox

# Chemin vers la clé publique RS256 de l'auth-service pour la vérification des JWT.
# Par défaut : keys/public.pem à la racine du projet (copié depuis auth-service/keys/).
# En production, pointer vers un volume partagé ou un secret manager.
JWT_PUBLIC_KEY_PATH=keys/public.pem
